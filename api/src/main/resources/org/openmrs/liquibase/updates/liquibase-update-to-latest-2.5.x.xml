<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext 
	    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
		http://www.liquibase.org/xml/ns/dbchangelog 
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-2.0.xsd">
	
	
	<changeSet author="rasztabigab" id="TRUNK-6001">
		<preConditions onFail="MARK_RAN">
			<columnExists tableName="cohort_member" columnName="start_date"/>
		</preConditions>
		<comment>Delete non-null constraint from column cohort_member.start_date</comment>
		<dropNotNullConstraint columnDataType="datetime" columnName="start_date" tableName="cohort_member"/>
	</changeSet>
	
	<changeSet id="TRUNK-5466-2020-06-19" author="jnsereko">
    	<preConditions onFail="MARK_RAN">
    		<not>
    			<columnExists tableName="location" columnName="supports_visits"/>
    		</not>
    	</preConditions>
    	<comment>Adding 'supports_visits' column to 'location' table</comment>
    	<addColumn tableName="location">
    		<column name="supports_visits" type="boolean">
    			<constraints nullable="true" />
    		</column>
    	</addColumn>
    	<addForeignKeyConstraint constraintName="location_supports_visits_fk"
								 baseTableName="location" 
								 baseColumnNames="supports_visits"
								 referencedTableName="location" 
								 referencedColumnNames="location_id" />
    </changeSet>
    
</databaseChangeLog>
