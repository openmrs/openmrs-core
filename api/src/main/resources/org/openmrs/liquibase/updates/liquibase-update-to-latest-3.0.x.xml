	<changeSet id="TRUNK-6649-2026-06-07" author="shivvani-r">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="obs_archive"/>
			</not>
		</preConditions>
		<comment>Add obs_archive and obs_archive_reference_range tables and global properties for Archiving Observations</comment>

		<createTable tableName="obs_archive">
			<column name="obs_id" type="INT">
				<constraints nullable="false" primaryKey="true"/>
			</column>
			<column name="person_id" type="INT">
				<constraints nullable="false"/>
			</column>
			<column defaultValueNumeric="0" name="concept_id" type="INT">
				<constraints nullable="false"/>
			</column>
			<column defaultValueComputed="NULL" name="encounter_id" type="INT"/>
			<column defaultValueComputed="NULL" name="order_id" type="INT"/>
			<column name="obs_datetime" type="DATETIME">
				<constraints nullable="false"/>
			</column>
			<column defaultValueComputed="NULL" name="location_id" type="INT"/>
			<column defaultValueComputed="NULL" name="obs_group_id" type="INT"/>
			<column name="accession_number" type="VARCHAR(255)"/>
			<column defaultValueComputed="NULL" name="value_group_id" type="INT"/>
			<column defaultValueComputed="NULL" name="value_coded" type="INT"/>
			<column defaultValueComputed="NULL" name="value_coded_name_id" type="INT"/>
			<column defaultValueComputed="NULL" name="value_drug" type="INT"/>
			<column defaultValueComputed="NULL" name="value_datetime" type="DATETIME"/>
			<column defaultValueComputed="NULL" name="value_numeric" type="DOUBLE"/>
			<column name="value_modifier" type="VARCHAR(2)"/>
			<column name="value_text" type="TEXT"/>
			<column name="value_complex" type="VARCHAR(1000)"/>
			<column name="comments" type="VARCHAR(255)"/>
			<column defaultValueNumeric="0" name="creator" type="INT">
				<constraints nullable="false"/>
			</column>
			<column name="date_created" type="DATETIME">
				<constraints nullable="false"/>
			</column>
			<column name="voided" type="BOOLEAN" defaultValueBoolean="false">
				<constraints nullable="false"/>
			</column>
			<column defaultValueComputed="NULL" name="voided_by" type="INT"/>
			<column defaultValueComputed="NULL" name="date_voided" type="DATETIME"/>
			<column name="void_reason" type="VARCHAR(255)"/>
			<column name="uuid" type="CHAR(38)">
				<constraints nullable="false" unique="true"/>
			</column>
			<column defaultValueComputed="NULL" name="previous_version" type="INT"/>
			<column name="form_namespace_and_path" type="VARCHAR(255)"/>
			<column defaultValue="FINAL" name="status" type="VARCHAR(16)">
				<constraints nullable="false"/>
			</column>
			<column name="interpretation" type="VARCHAR(32)"/>
			<column defaultValueComputed="NULL" name="changed_by" type="INT"/>
			<column defaultValueComputed="NULL" name="date_changed" type="DATETIME"/>
			<column defaultValueComputed="NULL" name="archived_by" type="INT"/>
			<column defaultValueComputed="NULL" name="date_archived" type="DATETIME"/>
		</createTable>

		<createTable tableName="obs_archive_reference_range">
			<column name="obs_reference_range_id" type="INT" autoIncrement="true">
				<constraints nullable="false" primaryKey="true"/>
			</column>
			<column name="obs_id" type="INT">
				<constraints nullable="false" unique="true"/>
			</column>
			<column defaultValueComputed="NULL" name="hi_absolute" type="DOUBLE"/>
			<column defaultValueComputed="NULL" name="hi_critical" type="DOUBLE"/>
			<column defaultValueComputed="NULL" name="hi_normal" type="DOUBLE"/>
			<column defaultValueComputed="NULL" name="low_absolute" type="DOUBLE"/>
			<column defaultValueComputed="NULL" name="low_critical" type="DOUBLE"/>
			<column defaultValueComputed="NULL" name="low_normal" type="DOUBLE"/>
			<column name="uuid" type="CHAR(38)">
				<constraints unique="true"/>
			</column>
			<column defaultValueComputed="NULL" name="archived_by" type="INT"/>
			<column defaultValueComputed="NULL" name="date_archived" type="DATETIME"/>
		</createTable>
		
		<createIndex indexName="idx_obs_archive_uuid" tableName="obs_archive">
			<column name="uuid"/>
		</createIndex>
		<createIndex indexName="idx_obs_archive_obs_group_id" tableName="obs_archive">
			<column name="obs_group_id"/>
		</createIndex>
		<createIndex indexName="idx_obs_archive_encounter_id" tableName="obs_archive">
			<column name="encounter_id"/>
		</createIndex>
		<createIndex indexName="idx_obs_archive_date_voided" tableName="obs_archive">
			<column name="date_voided"/>
		</createIndex>
	</changeSet>

	<changeSet id="TRUNK-6649-register-archiving-task" author="shivvani-r">
		<preConditions onFail="MARK_RAN">
			<and>
				<not>
					<sqlCheck expectedResult="1">
						SELECT COUNT(1) FROM scheduler_task_config WHERE name = 'Observation Archiving Job'
					</sqlCheck>
				</not>
				<sqlCheck expectedResult="1">
					SELECT COUNT(1) FROM users WHERE user_id = 1
				</sqlCheck>
			</and>
		</preConditions>
		<comment>Register the Observation Archiving task in the legacy scheduler table so it is visible in the Admin UI</comment>
		<insert tableName="scheduler_task_config">
			<column name="name" value="Observation Archiving Job"/>
			<column name="description" value="Periodically archives voided observations to the archive tables."/>
			<column name="schedulable_class" value="org.openmrs.scheduler.tasks.ObsArchivingTask"/>
			<column name="repeat_interval" valueNumeric="86400"/> <!-- 24 hours -->
			<column name="start_on_startup" valueBoolean="true"/>
			<column name="started" valueBoolean="false"/>
			<column name="date_created" valueDate="2026-06-07T00:00:00"/>
			<column name="created_by" valueNumeric="1"/>
			<column name="uuid" value="3c8c279a-8b1e-412e-9a88-7bba5b702344"/>
		</insert>
	</changeSet>

	<changeSet id="TRUNK-6649-drop-previous-version-fk" author="shivvani-r">
		<preConditions onFail="MARK_RAN">
			<foreignKeyConstraintExists foreignKeyTableName="obs" foreignKeyName="previous_version"/>
		</preConditions>
		<comment>Drop the previous_version foreign key constraint on the obs table to allow archiving old versions</comment>
		<dropForeignKeyConstraint baseTableName="obs" constraintName="previous_version"/>
	</changeSet>


</databaseChangeLog>
